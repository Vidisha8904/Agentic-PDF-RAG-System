    "# used to delete all data inside one collection\n",
    "import chromadb\n",
    "\n",
    "\n",
    "# collection = client.get_collection(name=\"deploy3\")  #change collection name\n",
    "\n",
    "# Get all IDs\n",
    "all_items = collection.get()\n",
    "all_ids = all_items[\"ids\"]\n",
    "\n",
    "# Delete all items using their IDs\n",
    "if all_ids:\n",
    "    collection.delete(ids=all_ids)\n",
    "    print(\"All data deleted successfully.\")\n",
    "else:\n",
    "    print(\"Collection is already empty.\")\n"
