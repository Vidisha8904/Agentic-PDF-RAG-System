    "# print all the documents/chunks of one file\n",
    "\n",
    "import chromadb\n",
    "import json\n",
    "\n",
    "def get_document_chunks(client, collection_name, filename):\n",
    "    \"\"\"\n",
    "    Get all chunks/documents, embeddings and metadata associated with a specific filename\n",
    "    \"\"\"\n",
    "    collection = client.get_collection(collection_name)\n",
    "\n",
    "    results = collection.get(\n",
    "        where={\"filename\": filename},\n",
    "        include=[\"embeddings\", \"metadatas\", \"documents\"]\n",
    "    )\n",
    "\n",
    "    if not results[\"ids\"] or len(results[\"ids\"]) == 0:\n",
    "        print(f\"No chunks found for filename: {filename}\")\n",
    "        return None\n",
    "\n",
    "    print(f\"Found {len(results['ids'])} chunks for file: {filename}\")\n",
    "\n",
    "    return {\n",
    "        \"ids\": results[\"ids\"],\n",
    "        \"documents\": results[\"documents\"],\n",
    "        \"embeddings\": results[\"embeddings\"],\n",
    "        \"metadatas\": results[\"metadatas\"]\n",
    "    }\n",
    "\n",
    "# Connect to ChromaDB\n",
    "client = chromadb.HttpClient(\n",
    "    host=\"chroma-vidisha-lb-1390783373.ap-southeast-1.elb.amazonaws.com\", \n",
    "    port=8000\n",
    ")\n",
    "\n",
    "# Set file and collection name\n",
    "filename = \"FMC130ParameterList.pdf\"  #change filename \n",
    "collection_name = \"nomic\"               #change collection name\n",
    "chunks_data = get_document_chunks(client, collection_name, filename)\n",
    "\n",
    "# Print all chunks\n",
    "if chunks_data:\n",
    "    print(\"\\n===== All Chunks =====\\n\")\n",
    "    for idx, (doc_id, doc, meta) in enumerate(zip(\n",
    "        chunks_data[\"ids\"],\n",
    "        chunks_data[\"documents\"],\n",
    "        chunks_data[\"metadatas\"]\n",
    "    )):\n",
    "        print(f\"\\n--- Chunk {idx+1} ---\")\n",
    "        print(f\"ID: {doc_id}\")\n",
    "        print(f\"Metadata: {meta}\")\n",
    "        print(\"Document:\")\n",
    "        print(doc)\n",
    "        print(\"\\n\" + \"-\"*50)\n",
    "\n",
    "    # Optional: Save to JSON\n",
    "    serializable_data = {\n",
    "        \"ids\": chunks_data[\"ids\"],\n",
    "        \"documents\": chunks_data[\"documents\"],\n",
    "        # \"metadatas\": chunks_data[\"metadatas\"],\n",
    "        \"embeddings\": [list(emb) for emb in chunks_data[\"embeddings\"]]\n",
    "    }\n",
    "\n",
    "    # Uncomment to save\n",
    "    # with open(f\"{filename.replace('.', '_')}_all_chunks.json\", \"w\") as f:\n",
    "    #     json.dump(serializable_data, f, indent=2)\n",
    "\n",
    "    # print(f\"\\nResults saved to {filename.replace('.', '_')}_all_chunks.json\")\n"
   ]
